---
import RootLayout from "@/layouts/RootLayout.astro";
import SEO from "@/components/seo/index.astro";
import Schema from "@/components/structured-data/index.astro";
import { siteMetadata } from "@/config/siteMetadata";
---

<RootLayout>
  <SEO
    slot="seo"
    title="Contact"
    description="Get in touch with Hamza EL IDRISSI for project inquiries, collaborations, or scheduling a meeting."
  />
  <Schema slot="ld+json" type="WebPage" />
  <div class="divide-y divide-border">
    {/* Page Header */}
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <h1
        class="text-center text-3xl font-extrabold leading-9 tracking-tight text-foreground sm:text-4xl sm:leading-10 md:text-6xl md:leading-14"
      >
        contact
      </h1>
      <p class="text-center text-lg leading-7 text-muted-foreground">
        Have a project in mind? Let's build something awesome together.
      </p>
    </div>

    {/* Contact Cards Section */}
    <div class="container max-w-4xl py-12 mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        {/* Email Card */}
        <div
          class="group flex flex-col justify-between p-6 md:p-8 rounded-2xl border border-border bg-card shadow-sm hover:shadow-md transition-all duration-300 relative overflow-hidden"
        >
          <div class="flex-1">
            <div class="inline-flex p-3 rounded-xl bg-violet-500/10 text-violet-500 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-3 text-foreground">Email Me</h2>
            <p class="text-sm text-muted-foreground mb-6 leading-relaxed">
              For project inquiries, direct collaboration opportunities, or general questions, feel free to drop me an email anytime.
            </p>
          </div>
          
          <div class="mt-auto space-y-3">
            <div class="flex items-center justify-between p-3.5 rounded-lg bg-muted/50 border border-border">
              <span id="email-text" class="font-mono text-sm select-all text-foreground font-medium">{siteMetadata.email}</span>
              <button 
                id="copy-email-btn"
                class="p-1.5 rounded-md hover:bg-muted text-muted-foreground hover:text-foreground transition-colors cursor-pointer relative"
                aria-label="Copy email address"
              >
                <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
                <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 hidden text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            </div>
            
            <a
              href={`mailto:${siteMetadata.email}`}
              class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl font-medium border border-border bg-background hover:bg-foreground hover:text-background transition-all duration-300 shadow-sm"
            >
              Send an Email
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>

        {/* Meeting Scheduler Card */}
        <div
          class="group flex flex-col justify-between p-6 md:p-8 rounded-2xl border border-border bg-card shadow-sm hover:shadow-md transition-all duration-300 relative overflow-hidden"
        >
          <div class="flex-1">
            <div class="inline-flex p-3 rounded-xl bg-violet-500/10 text-violet-500 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-3 text-foreground">Schedule a Meeting</h2>
            <p class="text-sm text-muted-foreground mb-6 leading-relaxed">
              If you have a potential project, let's skip the email back-and-forth and jump straight on a call to talk about your goals and ideas.
            </p>
          </div>
          
          <div class="mt-auto">
            <a
              href="https://calendar.proton.me/u/7/bookings#0nnDZp-Tbh9K7qlyClncmAOAPgkZp1IrIX8SQk8-ZWg="
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-3.5 px-4 rounded-xl font-medium bg-foreground text-background hover:bg-foreground/90 hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 shadow-md"
            >
              Book a Call
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</RootLayout>

<script>
  function setupCopyButton() {
    const copyBtn = document.getElementById("copy-email-btn");
    const emailText = document.getElementById("email-text")?.textContent;
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");

    if (copyBtn && emailText && copyIcon && checkIcon) {
      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(emailText);
          copyIcon.classList.add("hidden");
          checkIcon.classList.remove("hidden");
          
          setTimeout(() => {
            copyIcon.classList.remove("hidden");
            checkIcon.classList.add("hidden");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy text: ", err);
        }
      });
    }
  }

  // Setup on initial load
  setupCopyButton();

  // Setup on Astro page navigation (ClientRouter)
  document.addEventListener("astro:page-load", setupCopyButton);
</script>
